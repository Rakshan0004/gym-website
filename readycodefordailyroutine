<script>
  function toggle(header) {
    const block = header.parentElement;
    block.classList.toggle('open');
  }

  function switchDay(day) {
    document.querySelectorAll('.day-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.day-panel').forEach(p => p.classList.remove('active'));
    document.querySelector(`.day-tab[data-day="${day}"]`).classList.add('active');
    document.querySelector(`.day-panel[data-day="${day}"]`).classList.add('active');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  document.querySelectorAll('.day-tab').forEach(tab => {
    tab.addEventListener('click', () => switchDay(tab.dataset.day));
  });

  // Auto open first time-block per panel
  document.querySelectorAll('.day-panel').forEach(panel => {
    const first = panel.querySelector('.time-block');
    if (first) first.classList.add('open');
  });
</script>

