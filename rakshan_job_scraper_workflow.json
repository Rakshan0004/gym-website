    {
      "id": "node_11",
      "name": "🆕 Is This a New Job?",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2500, 80],
      "parameters": {
        "jsCode": "const sheetsRows = $input.all();\nconst jobData = $('📝 Parse Relevance Score').first().json;\n\nconst firstRow = sheetsRows[0]?.json;\nconst alreadyExists = firstRow && firstRow['Job ID'] && firstRow['Job ID'].toString().trim() !== '';\n\nreturn [{ json: { ...jobData, isNewJob: !alreadyExists } }];"
      }
    },
