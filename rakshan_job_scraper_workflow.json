      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [2740, 80],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": false,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
