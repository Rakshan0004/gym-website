    {
      "id": "node_13",
      "name": "✍️ Build Cover Letter AI Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2980, -20],
      "parameters": {
        "jsCode": "const job = $json;\n\nconst systemPrompt = `You are an expert career coach for the Indian tech job market. Write a punchy, tailored cover letter in exactly 220-240 words. Rules:\n- First line must mention the specific company and role\n- Highlight 2-3 specific matching skills with brief proof\n- One line showing you know the company (their product/industry)\n- Close with a confident call to action\n- No clichés: 'I am excited', 'passion for', 'team player'\n- Output ONLY the cover letter text. No subject, no greeting line header.`;\n\nconst userPrompt = `JOB: ${job.title} at ${job.company} (${job.location})\nKEY MATCH SKILL: ${job.keyMatch}\nJOB DESCRIPTION: ${job.description.substring(0, 2000)}\n\nCANDIDATE RESUME:\n${job.pResumeText}\n\nName: ${job.pYourName} | Email: ${job.pYourEmail} | Phone: ${job.pYourPhone}`;\n\nreturn [{ json: { ...job, coverLetterPayload: JSON.stringify({\n  model: 'gpt-4o-mini',\n  max_tokens: 600,\n  temperature: 0.75,\n  messages: [\n    { role: 'system', content: systemPrompt },\n    { role: 'user', content: userPrompt }\n  ]\n}) } }];"
      }
    },
    {
      "id": "node_14",
      "name": "🤖 AI Generate Cover Letter (OpenAI)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [3220, -20],
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $json.pOpenAIApiKey }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "contentType": "rawBody",
        "rawBody": "={{ $json.coverLetterPayload }}",
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      }
    },
    {
      "id": "node_15",
      "name": "📦 Merge Job + Cover Letter",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [3460, -20],
      "parameters": {
        "jsCode": "const aiResp = $input.first().json;\nconst jobData = $('✍️ Build Cover Letter AI Payload').first().json;\n\nlet coverLetter = 'Generation failed — please write manually.';\ntry {\n  coverLetter = aiResp.choices?.[0]?.message?.content?.trim() || coverLetter;\n} catch(e) {}\n\nconst now = new Date();\nconst dateStr = now.toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' });\nconst timeStr = now.toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit' });\n\nreturn [{\n  json: {\n    ...jobData,\n    coverLetter,\n    savedAt: `${dateStr} ${timeStr}`,\n    sheetRow: {\n      'Job ID': jobData.jobId,\n      'Title': jobData.title,\n      'Company': jobData.company,\n      'Location': jobData.location,\n      'Salary': jobData.salary,\n      'Remote': jobData.isRemote ? 'Yes' : 'No',\n      'Source': jobData.source,\n      'Is LinkedIn': jobData.isLinkedIn ? 'Yes' : 'No',\n      'Apply URL': jobData.applyUrl,\n      'Posted At': jobData.postedAt ? new Date(jobData.postedAt).toLocaleDateString('en-IN') : '',\n      'AI Score': jobData.relevanceScore,\n      'AI Reason': jobData.relevanceReason,\n      'Key Match': jobData.keyMatch,\n      'Top Concern': jobData.topConcern,\n      'Status': 'Saved — Pending Apply',\n      'Cover Letter': coverLetter,\n      'Applied At': '',\n      'Interview Date': '',\n      'Offer': '',\n      'Notes': '',\n      'Saved At': `${dateStr} ${timeStr}`\n    }\n  }\n}];"
      }
    },
