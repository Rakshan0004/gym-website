    {
      "id": "node_04",
      "name": "📊 Parse & Normalize Jobs",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [820, 300],
      "parameters": {
        "jsCode": "const prefs = $('⚙️ CLIENT CONFIG — Edit This Node Only').first().json;\nconst rawData = $input.first().json;\nconst jobs = rawData.data || [];\n\nif (jobs.length === 0) {\n  return [{ json: { _noJobs: true, ...prefs } }];\n}\n\nconst normalizedJobs = jobs.map(job => ({\n  jobId: job.job_id || '',\n  title: job.job_title || '',\n  company: job.employer_name || '',\n  location: [job.job_city, job.job_state, 'India'].filter(Boolean).join(', '),\n  description: (job.job_description || '').substring(0, 2500),\n  salary: job.job_min_salary\n    ? `₹${Math.round((job.job_min_salary || 0) / 100000)}L - ₹${Math.round((job.job_max_salary || 0) / 100000)}L`\n    : 'Not Specified',\n  jobType: job.job_employment_type || 'FULLTIME',\n  isRemote: job.job_is_remote || false,\n  postedAt: job.job_posted_at_datetime_utc || new Date().toISOString(),\n  applyUrl: job.job_apply_link || '',\n  isLinkedIn: (job.job_apply_link || '').includes('linkedin.com') || (job.job_publisher || '').toLowerCase().includes('linkedin'),\n  source: job.job_publisher || 'JSearch',\n  requiredSkills: (job.job_required_skills || []).join(', '),\n  requiredExperience: job.job_required_experience?.required_experience_in_months\n    ? Math.round(job.job_required_experience.required_experience_in_months / 12) + ' years'\n    : 'Not specified',\n\n  // Carry all prefs through\n  pJobTitle: prefs.jobTitle,\n  pSkills: prefs.skills,\n  pLocation: prefs.location,\n  pExperienceYears: prefs.experienceYears,\n  pSalaryMinLPA: prefs.salaryMinLPA,\n  pWorkMode: prefs.workMode,\n  pRelevanceThreshold: parseFloat(prefs.relevanceThreshold || '7'),\n  pCompaniesBlacklist: prefs.companiesBlacklist,\n  pYourName: prefs.yourName,\n  pYourEmail: prefs.yourEmail,\n  pYourPhone: prefs.yourPhone,\n  pLinkedinEmail: prefs.linkedinEmail,\n  pLinkedinPassword: prefs.linkedinPassword,\n  pSummaryRecipientEmail: prefs.summaryRecipientEmail,\n  pGoogleSheetId: prefs.googleSheetId,\n  pOpenAIApiKey: prefs.openAIApiKey,\n  pApifyApiKey: prefs.apifyApiKey,\n  pResumeText: prefs.resumeText\n}));\n\nreturn normalizedJobs.map(j => ({ json: j }));"
      }
    },
    {
      "id": "node_05",
