    {
      "id": "node_06",
      "name": "🏗️ Build AI Relevance Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1300, 180],
      "parameters": {
        "jsCode": "const job = $json;\n\nconst systemPrompt = `You are a job relevance scoring expert for the Indian tech job market. Score strictly — most jobs should score 5-7. Only genuinely excellent matches score 9-10. Respond ONLY with valid JSON (no markdown, no explanation):\n{\"score\": <integer 1-10>, \"reason\": \"<max 25 words>\", \"isBlacklisted\": <true|false>, \"keyMatch\": \"<top matching skill>\", \"topConcern\": \"<main gap or concern>\"}`;\n\nconst userPrompt = `CANDIDATE PROFILE:\nTarget Role: ${job.pJobTitle}\nSkills: ${job.pSkills}\nExperience: ${job.pExperienceYears} years\nPreferred Location: ${job.pLocation}\nMin Salary: ${job.pSalaryMinLPA} LPA\nWork Mode: ${job.pWorkMode}\nBlacklisted Companies: ${job.pCompaniesBlacklist}\n\nJOB:\nTitle: ${job.title}\nCompany: ${job.company}\nLocation: ${job.location}\nSalary: ${job.salary}\nType: ${job.jobType} | Remote: ${job.isRemote}\nRequired Skills: ${job.requiredSkills}\nRequired Exp: ${job.requiredExperience}\nDescription:\n${job.description.substring(0, 1800)}`;\n\nreturn [{ json: { ...job, openAIPayload: JSON.stringify({\n  model: 'gpt-4o-mini',\n  max_tokens: 250,\n  temperature: 0.2,\n  messages: [\n    { role: 'system', content: systemPrompt },\n    { role: 'user', content: userPrompt }\n  ]\n}) } }];"
      }
    },
    {
      "id": "node_07",
      "name": "🤖 AI Score Job (OpenAI)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1540, 180],
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $json.pOpenAIApiKey }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "contentType": "rawBody",
        "rawBody": "={{ $json.openAIPayload }}",
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      }
    },
    {
      "id": "node_08",
      "name": "📝 Parse Relevance Score",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1780, 180],
      "parameters": {
        "jsCode": "const aiResponse = $input.first().json;\nconst jobData = $('🏗️ Build AI Relevance Payload').first().json;\n\nlet score = 5, reason = 'Parse error', isBlacklisted = false, keyMatch = '', topConcern = '';\n\ntry {\n  const raw = aiResponse.choices?.[0]?.message?.content || '{}';\n  const cleaned = raw.replace(/```json|```/g, '').trim();\n  const parsed = JSON.parse(cleaned);\n  score = parseInt(parsed.score) || 5;\n  reason = parsed.reason || 'N/A';\n  isBlacklisted = parsed.isBlacklisted === true;\n  keyMatch = parsed.keyMatch || '';\n  topConcern = parsed.topConcern || '';\n} catch(e) {}\n\nreturn [{\n  json: {\n    ...jobData,\n    relevanceScore: score,\n    relevanceReason: reason,\n    isBlacklisted,\n    keyMatch,\n    topConcern\n  }\n}];"
      }
    },
    {
      "id": "node_09",
      "name": "✅ Is Relevant & Not Blacklisted?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [2020, 180],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": false,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond_score",
              "leftValue": "={{ $json.relevanceScore }}",
              "rightValue": "={{ $json.pRelevanceThreshold }}",
              "operator": {
                "type": "number",
                "operation": "gte"
              }
            },
            {
              "id": "cond_blacklist",
              "leftValue": "={{ $json.isBlacklisted }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "notEquals"
              }
            },
            {
              "id": "cond_nojobs",
              "leftValue": "={{ $json._noJobs }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "notEquals"
              }
            }
          ],
          "combinator": "and"
        }
      }
    },
